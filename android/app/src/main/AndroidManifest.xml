<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read the underlying network's DNS servers (systemDnsServers) so the mesh
         resolver can forward non-.ray queries upstream while the tunnel is up. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- The background send service (Share with Rayfish) runs as a data-sync FGS. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:name=".RayfishApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="${appName}"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rayfish">

        <!-- Sentry initializes manually in Telemetry (gated by the user's opt-out
             toggle). The SDK's SentryInitProvider ContentProvider otherwise runs
             before Application.onCreate, finds no manifest DSN, and crashes the
             process with "DSN is required". The io.sentry.auto-init=false
             meta-data is ignored in this SDK version, so remove the provider from
             the merged manifest outright; our manual init is the only init path. -->
        <provider
            android:name="io.sentry.android.core.SentryInitProvider"
            android:authorities="${applicationId}.SentryInitProvider"
            tools:node="remove" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="${appName}">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="rayfish" />
            </intent-filter>
        </activity>

        <!-- "Share with Rayfish" target: shows the recipient picker, then hands off
             to SendService for background delivery. -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="${shareLabel}"
            android:theme="@style/Theme.Rayfish">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- QR scanner pinned to portrait. zxing's default CaptureActivity
             follows the rotation sensor and comes up sideways on foldables;
             forcing the orientation here is the reliable fix. -->
        <activity
            android:name=".ui.qr.PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            tools:ignore="LockedOrientationActivity" />

        <service
            android:name=".SendService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".RayfishVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Rayfish mesh VPN tunnel" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>
</manifest>
